<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 不启用 App Sandbox,方便访问任意位置 ISO / 磁盘 -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- 文件访问 -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- 关闭库校验.
         App 用 posix_spawn 启动 bundle 里的 qemu-system-*. 父进程开了
         hardened runtime, kernel 会对 child 做 library validation 校验
         team identifier. 我们用 "Hell Dev" ad-hoc 身份, TeamIdentifier=not
         set, parent/child CDHash 不同 -> kernel 视为不同签名者 ->
         posix_spawn 返回 EPERM "Operation not permitted"。加这条让父进程
         明确放弃 child 的签名校验, 匹配 QEMU 自己 (qemu.entitlements)
         的声明。ad-hoc 签名下没这条就起不了 QEMU 子进程。 -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!--
      以下为虚拟化相关受限 entitlement,在 macOS 上需要 Apple Developer
      配置文件才能随 ad-hoc 签名的 App 一起使用,否则 AMFI 会在启动时
      SIGKILL 进程。P1 实际接入 VZ / QEMU 时再启用,并配套解决签名方案。

      <key>com.apple.security.virtualization</key><true/>
      <key>com.apple.security.hypervisor</key><true/>
      <key>com.apple.vm.networking</key><true/>
      <key>com.apple.vm.device-access</key><true/>
      <key>com.apple.security.cs.allow-jit</key><true/>
      <key>com.apple.security.cs.allow-unsigned-executable-memory</key><true/>
    -->
</dict>
</plist>
