+            fprintf(stderr, "couldn't add extra /memory@%"PRIx64" node\n",
+                    binfo->extra_ram_base);
+            goto fail;
+        }
+    }
+
     md_list = qmp_memory_device_list();
     for (MemoryDeviceInfoList *m = md_list; m != NULL; m = m->next) {
         MemoryDeviceInfo *mi = m->value;
diff --git a/hw/arm/virt.c b/hw/arm/virt.c
index 25fb2ba..5db826a 100644
--- a/hw/arm/virt.c
+++ b/hw/arm/virt.c
@@ -198,7 +198,9 @@ static const MemMapEntry base_memmap[] = {
     /* ...repeating for a total of NUM_VIRTIO_TRANSPORTS, each of that size */
     [VIRT_PLATFORM_BUS] =       { 0x0c000000, 0x02000000 },
     [VIRT_SECURE_MEM] =         { 0x0e000000, 0x01000000 },
-    [VIRT_PCIE_MMIO] =          { 0x10000000, 0x2eff0000 },
+    /* HellVM: 16MB 低地址 RAM 孔位于 0x10000000, 从原 PCIe MMIO 头部切出, 骗 Win11 bootmgr */
+    [VIRT_LOWRAM] =             { 0x10000000, 0x01000000 },
+    [VIRT_PCIE_MMIO] =          { 0x11000000, 0x2dff0000 },
     [VIRT_PCIE_PIO] =           { 0x3eff0000, 0x00010000 },
     [VIRT_PCIE_ECAM] =          { 0x3f000000, 0x01000000 },
     /* Actual RAM size depends on initial RAM and device memory settings */
@@ -2450,6 +2452,21 @@ static void machvirt_init(MachineState *machine)
     memory_region_add_subregion(sysmem, vms->memmap[VIRT_MEM].base,
                                 machine->ram);
 
+    /*
+     * HellVM: 在 0x10000000 挂一小块 RAM(VIRT_LOWRAM),用于兼容 Win11 ARM64 bootmgr。
+     * Windows ARM64 的 bootmgfw.efi 里保留了 x86 UEFI 的内存布局硬编码假设,
+     * 会对 0x10000000 附近的内存调 ConvertPages/SetMemoryAttributes。
+     * vanilla virt machine 这里是 PCIe MMIO, 操作失败 -> bootmgr 超时退出。
+     * 挂一小块 RAM 上去后 bootmgr 的内存操作能成功,正常进入 WinPE。
+     * Linux/BSD 不依赖这个区域,有这块 RAM 对它们无副作用。
+     */
+    {
+        MemoryRegion *lowram = g_new(MemoryRegion, 1);
+        memory_region_init_ram(lowram, NULL, "virt.lowram",
+                               vms->memmap[VIRT_LOWRAM].size, &error_fatal);
+        memory_region_add_subregion(sysmem, vms->memmap[VIRT_LOWRAM].base, lowram);
+    }
+
     cxl_fmws_update_mmio();
 
     virt_flash_fdt(vms, sysmem, secure_sysmem ?: sysmem);
@@ -2552,6 +2569,15 @@ static void machvirt_init(MachineState *machine)
     vms->bootinfo.ram_size = machine->ram_size;
     vms->bootinfo.board_id = -1;
     vms->bootinfo.loader_start = vms->memmap[VIRT_MEM].base;
+    /*
+     * HellVM: 把 VIRT_LOWRAM 宣告为第二个 /memory 节点。
+     * 搭配我们 patch 过的 EDK2 (QemuVirtMemInfoPeiLibConstructor):
+     *   - 按 PcdSystemMemoryBase 选主 RAM, 避免原来 "取最低地址" 触发的 ASSERT
+     *   - 额外 /memory 节点存新 GUID HOB, MemoryPeim 把它也注册为 EFI_RESOURCE_SYSTEM_MEMORY
+     * 这样 Win11 bootmgr 在 0x10000000 附近的 ConvertPages/SetMemoryAttributes 能成功。
+     */
+    vms->bootinfo.extra_ram_base = vms->memmap[VIRT_LOWRAM].base;
+    vms->bootinfo.extra_ram_size = vms->memmap[VIRT_LOWRAM].size;
     vms->bootinfo.get_dtb = machvirt_dtb;
     vms->bootinfo.skip_dtb_autoload = true;
     vms->bootinfo.firmware_loaded = firmware_loaded;
@@ -3225,6 +3251,11 @@ static int virt_hvf_get_physical_address_range(MachineState *ms)
     int default_ipa_size = hvf_arm_get_default_ipa_bit_size();
     int max_ipa_size = hvf_arm_get_max_ipa_bit_size();
 
+    /* HellVM (UTM patch): 当 hvf 无法报告最大 IPA 位数时退出, 让 machvirt_init 用默认 */
+    if (max_ipa_size == 0) {
+        return 0;
+    }
+
     /* We freeze the memory map to compute the highest gpa */
     virt_set_memmap(vms, max_ipa_size);
 
@@ -3304,6 +3335,8 @@ static void virt_machine_class_init(ObjectClass *oc, const void *data)
     machine_class_allow_dynamic_sysbus_dev(mc, TYPE_ARM_SMMUV3);
 #ifdef CONFIG_TPM
     machine_class_allow_dynamic_sysbus_dev(mc, TYPE_TPM_TIS_SYSBUS);
+    /* HellVM (UTM patch): 允许动态添加 TPM CRB sysbus 设备 */
+    machine_class_allow_dynamic_sysbus_dev(mc, TYPE_TPM_CRB_SYSBUS);
 #endif
     mc->block_default_type = IF_VIRTIO;
     mc->no_cdrom = 1;
