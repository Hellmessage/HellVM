diff --git a/hw/arm/boot.c b/hw/arm/boot.c
index b916602..5db7a0e 100644
--- a/hw/arm/boot.c
+++ b/hw/arm/boot.c
@@ -578,6 +578,17 @@ int arm_load_dtb(hwaddr addr, const struct arm_boot_info *binfo,
         }
     }
 
+    /* HellVM: 额外低地址 RAM 区(给 Win11 ARM64 bootmgr 用) */
+    if (binfo->extra_ram_size > 0) {
+        rc = fdt_add_memory_node(fdt, acells, binfo->extra_ram_base,
+                                 scells, binfo->extra_ram_size, -1);
